#\!/bin/bash

# Switch between kinesis.kbd and lenovo.kbd configurations
# Usage: ./switch-keyboard [kinesis|lenovo]

SCRIPT_DIR="/home/sspaeti/.config/kanata"
TARGET_FILE="$SCRIPT_DIR/kanata.kbd"

# if [[ $EUID -ne 0 ]]; then
#     echo "This script must be run as root"
#     exit 1
# fi

# If no argument provided, detect current config and switch
if [ $# -eq 0 ]; then
    if cmp -s "$TARGET_FILE" "$SCRIPT_DIR/kinesis.kbd"; then
        CONFIG="lenovo"
    else
        CONFIG="kinesis"
    fi
else
    CONFIG="$1"
fi

case "$CONFIG" in
    kinesis)
        sudo cp "$SCRIPT_DIR/kinesis.kbd" "$TARGET_FILE"
        LABEL="Kinesis"
        ;;
    lenovo)
        sudo cp "$SCRIPT_DIR/lenovo.kbd" "$TARGET_FILE"
        LABEL="Laptop"
        ;;
    *)
        echo "Usage: $0 [kinesis|lenovo]"
        echo "If no argument provided, automatically switches to the other config"
        exit 1
        ;;
esac

sudo systemctl restart kanata
echo "Switched to $LABEL keyboard"
